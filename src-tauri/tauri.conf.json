{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AEGIS",
  "version": "0.9.0",
  "identifier": "com.aegis.security",
  "build": {
    "beforeDevCommand": "NEXT_PUBLIC_IS_TAURI=true NEXT_PUBLIC_API_URL=https://aegis-security.ru npm run dev",
    "beforeBuildCommand": "NEXT_PUBLIC_IS_TAURI=true NEXT_PUBLIC_API_URL=https://aegis-security.ru npm --prefix /Users/ekaterinasacko/Desktop/AEGIS_FINAL/frontend run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "AEGIS — Автономный цифровой иммунитет",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
