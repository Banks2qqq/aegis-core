#!/usr/bin/expect -f
# Usage: VPS_PASSWORD=yourpass ./check_vps.exp
set timeout 30
if {![info exists env(VPS_PASSWORD)]} {
  puts stderr "Set VPS_PASSWORD"
  exit 1
}
set pass $env(VPS_PASSWORD)
spawn ssh -o StrictHostKeyChecking=no root@178.236.16.101 "systemctl is-active aegis-agent nginx"
expect {
  "password:" { send "$pass\r"; exp_continue }
  eof
}
