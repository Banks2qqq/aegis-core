# Copy to /etc/aegis/agent.env and fill secrets (chmod 600).
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
AI_API_KEY=
XAI_API_KEY=
XAI_MODEL=grok-3
RUST_LOG=info

# PR4 — Action plane enforcement (Linux VPS)
# Real healing patch files under data/healing/applied/
AEGIS_HEAL_APPLY=1
# Contain JSON records + host marker; iptables chain AEGIS_CONTAIN when available
AEGIS_CONTAIN_ENFORCE=1
# Optional: append DROP in AEGIS_CONTAIN for severity>=0.9 (use with care)
# AEGIS_CONTAIN_DROP=0
# Optional: jump OUTPUT -> AEGIS_CONTAIN (requires root + review)
# AEGIS_CONTAIN_HOOK_OUTPUT=0

# PR5 — Federation peer auth (same value on all nodes)
FEDERATION_SHARED_SECRET=CHANGE_ME_openssl_rand_hex_32
# Dev only: allow /federation/* without token when secret unset
# AEGIS_FEDERATION_INSECURE=1
# Optional mTLS client certs for outbound peer calls
# AEGIS_FEDERATION_CLIENT_CERT=/etc/aegis/federation/client.pem
# AEGIS_FEDERATION_CLIENT_KEY=/etc/aegis/federation/client-key.pem
# Optional CA pin for outbound federation HTTPS
# AEGIS_FEDERATION_CA_CERT=/etc/aegis/federation/ca.pem

# Production API keys (generate: deploy/production-generate-api-keys.sh)
# AEGIS_DEV_MODE=0
# AEGIS_MONITOR_API_KEY=
# AEGIS_DASHBOARD_API_KEY=

# Scout 2.0 — optional TI keys (without them sources are skipped gracefully)
# abuse.ch Auth-Key (ThreatFox, URLhaus, MalwareBazaar): https://auth.abuse.ch/
# ABUSECH_API_KEY=
# OTX_API_KEY=
# VT_API_KEY=
# XFORCE_API_KEY=

# PR6 — Pilot / ops: backups + smoke (see deploy/RUNBOOK.md, deploy/smoke/, deploy/backup-aegis.sh)
