{
  "uid": "aegis-scout",
  "title": "AEGIS Scout 2.0",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Pipeline runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(aegis_scout_pipeline_runs_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Last findings count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "aegis_scout_findings_last", "legendFormat": "findings" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Heal queued (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "aegis_scout_heal_queued_total", "legendFormat": "heal" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Intel sources (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(aegis_scout_intel_source_total{status=\"ok\"}[5m])) by (source)",
          "legendFormat": "{{source}} ok"
        },
        {
          "expr": "sum(rate(aegis_scout_intel_source_total{status=\"error\"}[5m])) by (source)",
          "legendFormat": "{{source}} err"
        },
        {
          "expr": "sum(rate(aegis_scout_intel_source_total{status=\"skipped\"}[5m])) by (source)",
          "legendFormat": "{{source}} skip"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Pipeline duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aegis_scout_pipeline_duration_seconds_bucket[5m])) by (le, result))",
          "legendFormat": "{{result}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "KB items ingested",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(aegis_scout_items_collected_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39
}
