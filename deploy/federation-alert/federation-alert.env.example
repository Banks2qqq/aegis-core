# Copy to /etc/aegis/federation-alert.env on primary VPS (chmod 600).
# Message your bot once in Telegram, then run setup-telegram-alert.sh to resolve chat_id.

PRIMARY_URL=https://aegis-security.ru
API_KEY=test-key-enterprise
ALERT_SYNC_LATENCY_MS=30000

# From @BotFather
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Optional: loaded from /etc/aegis/agent.env if unset
# FEDERATION_SHARED_SECRET=
